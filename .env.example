# CarGuru Root Environment Variables
# Copy this to .env and fill in the values

# --- Database ---
POSTGRES_DB=carguru
POSTGRES_USER=carguru_user
POSTGRES_PASSWORD=carguru_pass

# --- Backend ---
BACKEND_PORT=3003

# --- Frontend ---
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3003/api

# --- ElevenLabs (Client-side) ---
NEXT_PUBLIC_ELEVEN_LABS_AGENT_ID=your_agent_id_here
